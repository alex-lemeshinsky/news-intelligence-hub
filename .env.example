# Application
NODE_ENV=development
WEB_PORT=3000
API_PORT=3001

# PostgreSQL
POSTGRES_DB=news_intelligence_hub
POSTGRES_USER=nih
POSTGRES_PASSWORD=nih_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nih:nih_password@localhost:5432/news_intelligence_hub?schema=public

# Redis / BullMQ
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Bull Board basic auth
BULL_BOARD_ENABLED=true
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change_me

# Auth
JWT_SECRET=change_me
SESSION_SECRET=change_me
DEV_EMAIL_CONFIRMATION=true

# LLM provider selection
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_CONCURRENCY=2
LLM_REQUEST_TIMEOUT_MS=30000
LLM_MAX_INPUT_TOKENS=12000
LLM_MAX_OUTPUT_TOKENS=2000

# LLM credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Feed processing
FEED_PULL_CRON=*/15 * * * *
ARTICLE_MIN_CONTENT_CHARS=500
ARTICLE_MAX_CONTENT_CHARS=30000
