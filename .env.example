# Application
#
# The values below target the development flow (docker-compose.dev.yml: apps run on
# the host against containerized Postgres/Redis). The full-stack flow
# (docker-compose.yml) overrides DATABASE_URL, REDIS_URL, and
# API_INTERNAL_BASE_URL with compose-network hostnames automatically, so the same
# .env works for both flows.
NODE_ENV=development
# Host ports the full-stack web/API containers are published on.
WEB_PORT=3000
API_PORT=3001
# Allowed browser origin for API CORS.
WEB_ORIGIN=http://localhost:3000
# Browser -> API base URL. Inlined into the web bundle at BUILD time; for the
# full-stack image, override with the web build-arg of the same name if the
# public URL differs from http://localhost:3001.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# Server-side (SSR) -> API base URL. Overridden to http://api:3001 by the
# full-stack compose file.
API_INTERNAL_BASE_URL=http://localhost:3001

# PostgreSQL
POSTGRES_DB=news_intelligence_hub
POSTGRES_USER=nih
POSTGRES_PASSWORD=nih_password
# Host port used when either compose file publishes the database container.
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nih:nih_password@localhost:5432/news_intelligence_hub?schema=public

# Redis / BullMQ
# Host port used when either compose file publishes the Redis container.
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=4
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_BACKOFF_MS=5000

# Bull Board basic auth
BULL_BOARD_ENABLED=true
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change_me

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
AUTH_COOKIE_NAME=nih_access_token
AUTH_COOKIE_MAX_AGE_SECONDS=86400
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
DEV_EMAIL_CONFIRMATION=true

# LLM provider selection
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_CONCURRENCY=2
LLM_REQUEST_TIMEOUT_MS=30000
LLM_MAX_INPUT_TOKENS=12000
LLM_MAX_OUTPUT_TOKENS=2000
LLM_CACHE_LOCK_TTL_MS=120000
LLM_CACHE_LOCK_WAIT_MS=30000
LLM_CACHE_LOCK_RETRY_MS=250

# LLM credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Feed processing
FEED_PULL_CRON=*/15 * * * *
ARTICLE_MIN_CONTENT_CHARS=500
ARTICLE_MAX_CONTENT_CHARS=30000

# Demo seed data
#
# The seed script (npm run db:seed, or the one-shot "seed" container in
# docker-compose.yml) creates one confirmed demo user with a populated
# article feed and relationship graph so reviewers see working data without
# configuring LLM keys. Set SEED_DEMO_DATA=false to skip seeding. These are
# development-only demo credentials, not real secrets; change them before any
# non-local use.
SEED_DEMO_DATA=true
SEED_DEMO_EMAIL=demo@news-intelligence.local
SEED_DEMO_PASSWORD=demo-password-change-me
