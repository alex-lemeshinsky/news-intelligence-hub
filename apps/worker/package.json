{
  "name": "@nih/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "predev": "npm --prefix ../../packages/shared run build",
    "dev": "tsx watch src/main.ts",
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.json",
