{
  "name": "@nih/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "predev": "npm --prefix ../../packages/shared run build && npm --prefix ../../packages/database run build",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "prebuild": "npm --prefix ../../packages/shared run build && npm --prefix ../../packages/database run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "prelint": "npm --prefix ../../packages/shared run build && npm --prefix ../../packages/database run build",
    "lint": "eslint src && tsc -p tsconfig.json --noEmit",
    "test": "NODE_ENV=test tsx --test src/*.spec.ts"
  },
  "dependencies": {
    "@nih/database": "file:../../packages/database",
    "@nih/shared": "file:../../packages/shared",
    "bullmq": "^5.34.2",
    "ioredis": "^5.8.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  }
}
